SEENAV_HOST=0.0.0.0
SEENAV_PORT=8787

# mock keeps the backend fully local and deterministic for demos.
# openai_compatible sends frames to a vision model endpoint that accepts
# /chat/completions style image_url messages.
SEENAV_PROVIDER=mock

VISION_MODEL_BASE_URL=https://api.example.com/v1
VISION_MODEL_API_KEY=replace-me
VISION_MODEL_NAME=vision-model-name
