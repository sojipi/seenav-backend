SEENAV_HOST=0.0.0.0
SEENAV_PORT=8787

# mock keeps the backend fully local and deterministic for demos.
# openai_compatible sends frames to a vision model endpoint that accepts
# /chat/completions style image_url messages.
# anthropic_compatible sends the parking map and current frame to
# /v1/messages style image content.
SEENAV_PROVIDER=mock

VISION_MODEL_BASE_URL=https://api.example.com/v1
VISION_MODEL_API_KEY=replace-me
VISION_MODEL_NAME=vision-model-name

ANTHROPIC_BASE_URL=https://newapi.zenmb.com
ANTHROPIC_API_KEY=replace-me
ANTHROPIC_MODEL=claude-sonnet-4-5-20250929-thinking

# both sends x-api-key and Authorization: Bearer for proxy compatibility.
# Use x-api-key for official Anthropic or authorization for OpenAI-style proxies.
ANTHROPIC_AUTH_HEADER=both
ANTHROPIC_VERSION=2023-06-01
